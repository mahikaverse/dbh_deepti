generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  password      String
  role          Role           @default(USER)
  createdAt     DateTime       @default(now())

  artworks      Artwork[]
  inquiries     Inquiry[]
  artistProfile ArtistProfile?

  likes         Like[]
  wishlists     Wishlist[]
}

model Artwork {
  id String @id @default(cuid())

  title       String
  description String

  imageUrl String

  category ArtworkCategory

  medium String?

  width  Float?
  height Float?

  price Decimal @db.Decimal(10, 2)

  frameAvailable Boolean @default(false)

  isApproved Boolean @default(false)

  isAvailable Boolean @default(true)

  artistId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  artist User @relation(fields: [artistId], references: [id])

  inquiries Inquiry[]

  likes Like[]
  wishlists Wishlist[]
}

enum ArtistVerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

model ArtistProfile {
  id String @id @default(cuid())

  userId String @unique

  phone String
  bio   String?

  address String

  dob DateTime

  instagram String?

  portfolio String?

  profileImage String?

  status ArtistVerificationStatus @default(PENDING)

  rejectionReason String?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Inquiry {
  id             String        @id @default(cuid())
  userId         String
  artworkId      String
  preferredFrame String?
  preferredSize  String?
  message        String?
  status         InquiryStatus @default(NEW)
  createdAt      DateTime      @default(now())
  artwork        Artwork       @relation(fields: [artworkId], references: [id])
  user           User          @relation(fields: [userId], references: [id])
}

enum ArtworkCategory {
  SPIRITUAL
  NATURE
  PORTRAIT
  ABSTRACT
  LANDSCAPE
  SKETCH
  HERITAGE
  MODERN
  OTHER
}

enum Role {
  USER
  ARTIST
  ADMIN
}

enum InquiryStatus {
  NEW
  CONTACTED
  CONFIRMED
  COMPLETED
  CANCELLED
}

model Like {
  id String @id @default(cuid())

  userId String
  artworkId String

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  artwork Artwork @relation(fields: [artworkId], references: [id], onDelete: Cascade)

  @@unique([userId, artworkId])
}

model Wishlist {
  id String @id @default(cuid())

  userId String
  artworkId String

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  artwork Artwork @relation(fields: [artworkId], references: [id], onDelete: Cascade)

  @@unique([userId, artworkId])
}